CORERADIO_IMAGE=coreradio-index:local
CORERADIO_CONTAINER_NAME=coreradio-index
CORERADIO_PORT=8080
CORERADIO_DATA_PATH=./data
CORERADIO_DOWNLOADS_PATH=./downloads
PUBLIC_BASE_URL=http://localhost:8080
CORE_BASE_URL=https://coreradio.online
DEFAULT_REFRESH_PAGES=2
MAX_REFRESH_PAGES=20
CRAWLER_CONCURRENCY=3
CRAWLER_DELAY_MS=350
REQUEST_TIMEOUT_MS=25000
DOWNLOAD_TIMEOUT_MS=120000
# Keep false unless you explicitly want the app to follow ad-shortened mirrors normally.
ALLOW_AD_LINKS=false

# Optional Lidarr callback. When set, progress/completion asks Lidarr to refresh monitored downloads.
LIDARR_URL=
LIDARR_API_KEY=
LIDARR_REFRESH_DEBOUNCE_MS=10000
LIDARR_REQUEST_TIMEOUT_MS=10000
