COREARR_IMAGE=corearr:local
COREARR_CONTAINER_NAME=corearr
COREARR_PORT=8080

# Set this to the URL Lidarr and your browser can reach.
PUBLIC_BASE_URL=http://10.19.21.114:8080

# Use absolute host paths on the Docker/Portainer host.
COREARR_DATA_PATH=/opt/corearr/data
COREARR_DOWNLOADS_PATH=/downloads/corearr

CORE_BASE_URL=https://coreradio.online
DEFAULT_REFRESH_PAGES=2
MAX_REFRESH_PAGES=20
CRAWLER_CONCURRENCY=3
CRAWLER_DELAY_MS=350
REQUEST_TIMEOUT_MS=25000
DOWNLOAD_TIMEOUT_MS=120000
ALLOW_AD_LINKS=false

# Optional: set these to make CoreRadio Index trigger Lidarr queue/import refreshes.
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=replace-with-lidarr-api-key
LIDARR_REFRESH_DEBOUNCE_MS=10000
LIDARR_REQUEST_TIMEOUT_MS=10000
