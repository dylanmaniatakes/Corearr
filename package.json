{
  "name": "corearr",
  "version": "0.1.0",
  "description": "Corearr indexes Core Radio releases and exposes Lidarr-friendly Torznab/qBittorrent endpoints.",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/DylanManiatakes/Corearr.git"
  },
  "homepage": "https://github.com/DylanManiatakes/Corearr",
  "bugs": {
    "url": "https://github.com/DylanManiatakes/Corearr/issues"
  },
  "scripts": {
    "dev": "concurrently \"tsx watch server/index.ts\" \"vite --host 0.0.0.0\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.2",
    "lucide-react": "^0.561.0",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sanitize-filename": "^1.6.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
